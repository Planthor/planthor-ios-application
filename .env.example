# Copy to .env — do NOT commit .env
# These are reference values only; actual config is compile-time via --dart-define-from-file

# Run dev:  flutter run --dart-define-from-file=dart_defines/dev.json
# Run prod: flutter run --dart-define-from-file=dart_defines/prod.json
#
# Copy the relevant dart_defines/*.example.json → dart_defines/<env>.json before running.
